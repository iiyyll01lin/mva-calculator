{
  "name": "mva-v2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test": "vitest run tests/unit && vitest run tests/functional && vitest run tests/regression",
    "test:unit": "vitest run tests/unit",
    "test:functional": "vitest run tests/functional",
    "test:regression": "vitest run tests/regression",
    "test:e2e": "bash tests/e2e/smoke.sh",
    "test:all": "vitest run tests/unit && vitest run tests/functional && vitest run tests/regression && bash tests/e2e/smoke.sh"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
